# RTMP Squid configuration. Copy to .env (setup.sh does this for you) and edit.
# A real environment variable always overrides the value here.

# Access token gating the dashboard + API. setup.sh generates a random one.
AUTH_TOKEN=change-me-to-a-long-secret

# Bind address + port. Keep 127.0.0.1 unless behind a TLS reverse proxy.
HOST=127.0.0.1
PORT=3001

# The only directory the app may read. Everything is confined here.
# Defaults to a `media/` folder next to the repo if unset. Point it at your movies.
MEDIA_ROOT=/path/to/your/media

# Folder the auto-queue pulls random movies from (defaults to MEDIA_ROOT).
LIBRARY_DIR=/path/to/your/media

# Ignore video files smaller than this many MB when scanning the library.
MIN_MOVIE_MB=5
